# Container image pushed by GitHub Actions
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com
BACKEND_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/hearo-backend:latest

# Application
SERVER_PORT=8081

# Amazon RDS MySQL
DB_URL=jdbc:mysql://your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:3306/hearO?useSSL=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=hearo_app
DB_PASSWORD=change-me

JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Secrets: set real values only in the EC2 .env file.
MAIL_USERNAME=
MAIL_PASSWORD=
JWT_SECRET=change-me

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=hearo-s3-bucket

CLOVA_SPEECH_SECRET=
CLOVA_SPEECH_INVOKE_URL=
